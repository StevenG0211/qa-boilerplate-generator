{
  "name": "qa-boilerplate-generator",
  "displayName": "QA Boilerplate Generator",
  "description": "Scaffold Playwright, WebdriverIO, and Cypress test projects from official or imported presets.",
  "version": "0.1.0",
  "private": true,
  "publisher": "qa-boilerplate-gen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StevenG0211/qa-boilerplate-generator.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:qaBoilerplateGen.generateProject"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qaBoilerplateGen.generateProject",
        "title": "Generate Test Project",
        "category": "QA Gen",
        "enablement": "workspaceFolderCount > 0"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "compile:tests": "tsc -p tsconfig.test.json",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test:extension": "npm run compile && npm run compile:tests && node ./out/test/runTest.js",
    "package": "npm run compile && vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@qa-boilerplate/generator": "*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "glob": "^11.0.3",
    "mocha": "^11.1.0",
    "typescript": "^5"
  }
}
