{
  "name": "qa-boilerplate-generator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @qa-boilerplate/web",
    "build": "npm run build -w @qa-boilerplate/web",
    "start": "npm run start -w @qa-boilerplate/web",
    "lint": "npm run lint -w @qa-boilerplate/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test -w @qa-boilerplate/generator && npm run test -w @qa-boilerplate/web",
    "compile:extension": "npm run compile -w qa-boilerplate-generator",
    "validate:presets": "tsx scripts/validate-presets.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  }
}
