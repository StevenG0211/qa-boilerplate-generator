{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qa-boilerplate-generator.local/preset.schema.json",
  "title": "QA Boilerplate Generator Preset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "description",
    "source",
    "tags",
    "config"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source": { "enum": ["official", "community", "uploaded"] },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "config": { "$ref": "#/$defs/config" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": { "type": "string", "minLength": 1 },
        "homepage": { "type": "string", "format": "uri" },
        "minGeneratorVersion": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectName",
        "framework",
        "language",
        "pattern",
        "reporting",
        "ci",
        "linting",
        "env",
        "validation",
        "apiTesting"
      ],
      "properties": {
        "projectName": { "type": "string", "minLength": 1 },
        "framework": { "enum": ["wdio", "playwright", "cypress"] },
        "language": { "enum": ["ts", "js"] },
        "pattern": { "enum": ["pom", "screenplay", "none"] },
        "reporting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allure", "html", "dot"],
          "properties": {
            "allure": { "type": "boolean" },
            "html": { "type": "boolean" },
            "dot": { "type": "boolean" }
          }
        },
        "ci": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider"],
          "properties": {
            "provider": { "enum": ["github", "gitlab", "none"] }
          }
        },
        "linting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eslint", "prettier"],
          "properties": {
            "eslint": { "type": "boolean" },
            "prettier": { "type": "boolean" }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dotenv"],
          "properties": {
            "dotenv": { "type": "boolean" }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zod"],
          "properties": {
            "zod": { "type": "boolean" }
          }
        },
        "apiTesting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool"],
          "properties": {
            "tool": {
              "enum": ["supertest", "axios", "playwright-built-in", "none"]
            }
          }
        }
      }
    }
  }
}
